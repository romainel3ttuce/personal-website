{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "correctness": {
        "noUnknownAtRules": {
          "level": "off",
          "options": {
            "ignoreAtRules": ["theme", "tailwind", "apply", "layer", "config", "import"]
          }
        }
      }
    }
  }
}